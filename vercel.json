{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "epl_match_simulator/build/web",
  "env": {
    "CLAUDE_API_KEY": "@claude_api_key"
  },
  "functions": {
    "api/predictMatch.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}
