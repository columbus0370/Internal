{
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "build/web",
  "installCommand": "npm install",
  "env": {
    "FLUTTER_BUILD_MODE": "release"
  },
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs@18"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
