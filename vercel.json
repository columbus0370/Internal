{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bash vercel-build.sh",
  "outputDirectory": "epl_match_simulator/build/web",
  "installCommand": "npm install",
  "functions": {
    "api/**": {
      "maxDuration": 60,
      "memory": 512
    }
  },
  "env": {
    "FLUTTER_BUILD_MODE": "release"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

